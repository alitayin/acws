# Recommended for VPS deployment behind Nginx/Caddy
HOST=127.0.0.1
INTERNAL_HOST=127.0.0.1
PROXY_PORT=3000
HONO_PORT=3043
WS_PORT=3044
DB_PATH=./order-server-db

TLS_ENABLED=false
HTTP_REDIRECT_ENABLED=false
REDIRECT_HOST=acws.alitayin.com

CORS_ORIGIN=https://acws.alitayin.com
BALANCE_CACHE_MS=300000
BALANCE_REFRESH_MS=60000
JSON_BODY_LIMIT=1mb

# Optional: override Chronik upstreams
# CHRONIK_ENDPOINTS=https://chronik.e.cash,https://chronik-native2.fabien.cash
# CHRONIK_ENDPOINTS_AGORA=https://chronik-native2.fabien.cash,https://chronik-native3.fabien.cash

# Optional: enable built-in TLS instead of a reverse proxy
# TLS_ENABLED=true
# PROXY_PORT=443
# HTTP_REDIRECT_ENABLED=true
# HTTP_REDIRECT_PORT=80
# TLS_KEY_PATH=/etc/letsencrypt/live/acws.alitayin.com/privkey.pem
# TLS_CERT_PATH=/etc/letsencrypt/live/acws.alitayin.com/fullchain.pem
# TLS_CA_PATH=/etc/letsencrypt/live/acws.alitayin.com/chain.pem
